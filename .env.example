# Gateway
DATABASE_URL=postgres://postgres:postgres@localhost:5432/newchat
REDIS_URL=redis://localhost:6379
APP_ORIGIN=http://localhost:3000
SESSION_COOKIE_NAME=nc_session
SESSION_TTL_SECONDS=604800
AUTH_RATE_LIMIT_PER_MIN=30
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads
KEY_ENCRYPTION_KEY=change-this-to-a-strong-random-string
SECURE_COOKIES=false
ADMIN_EMAIL=admin@example.com
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=
DISABLE_PASSWORD_REGISTER=true
DISABLE_PASSWORD_LOGIN=true
ABUSE_THROTTLE_DURATION_MINUTES=20
ABUSE_TEMP_BAN_DURATION_MINUTES=60
ABUSE_THROTTLE_SCORE_THRESHOLD=55
ABUSE_BAN_SCORE_THRESHOLD=95
ABUSE_STREAM_CONCURRENCY_LIMIT=2
TELEGRAM_ALERT_WEBHOOK_URL=
AGENT_MODE_ENABLED=true
AGENT_MAX_STEPS=6
AGENT_TOOL_TIMEOUT_MS=12000
AGENT_FETCH_TIMEOUT_MS=10000
AGENT_FETCH_MAX_BYTES=500000
AGENT_WEB_SEARCH_RESULT_LIMIT=5
AGENT_PYTHON_TIMEOUT_MS=8000
AGENT_MODEL_MAX_OUTPUT_TOKENS=900

# Web
GATEWAY_URL_INTERNAL=http://localhost:3001
