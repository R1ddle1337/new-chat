# Gateway
DATABASE_URL=postgres://postgres:postgres@localhost:5432/newchat
REDIS_URL=redis://localhost:6379
APP_ORIGIN=http://localhost:3000
SESSION_COOKIE_NAME=nc_session
SESSION_TTL_SECONDS=604800
AUTH_RATE_LIMIT_PER_MIN=30
V1_RATE_LIMIT_PER_MIN=120
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads
KEY_ENCRYPTION_KEY=change-this-to-a-strong-random-string
SECURE_COOKIES=false
ADMIN_EMAIL=admin@example.com

# Web
GATEWAY_URL_INTERNAL=http://localhost:3001
